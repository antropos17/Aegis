{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp@latest"],
      "description": "Fresh library docs on demand (Svelte, Electron, Vitest, Three.js)"
    },
    "svelte": {
      "command": "npx",
      "args": ["-y", "@sveltejs/mcp@latest"],
      "description": "Svelte 5 docs, autofixer, component patterns"
    }
  }
}
