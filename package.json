{
  "name": "aegis",
  "version": "0.4.0-alpha",
  "description": "Independent AI agent oversight layer — monitors what AI agents do on your local machine",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && node scripts/launch.js",
    "dev": "vite",
    "build:renderer": "vite build",
    "build:demo": "vite build --mode demo",
    "build": "electron-builder --publish never",
    "dist": "electron-builder --publish never",
    "format": "prettier --write 'src/**/*.{js,ts,svelte,css,html}' '*.{js,ts,json}'",
    "format:check": "prettier --check 'src/**/*.{js,ts,svelte,css,html}' '*.{js,ts,json}'",
    "lint": "npx eslint src/",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,ts,svelte,css,html}": "prettier --write",
    "*.{js,ts,json}": "prettier --write"
  },
  "build": {
    "appId": "com.aegis.oversight",
    "productName": "AEGIS - AI Monitoring & Threat Detection",
    "copyright": "Copyright © 2026 Ruslan",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "src/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main/main.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antropos17/Aegis.git"
  },
  "homepage": "https://github.com/antropos17/Aegis",
  "bugs": {
    "url": "https://github.com/antropos17/Aegis/issues"
  },
  "author": "Ruslan Murtuzaliyev",
  "license": "MIT",
  "keywords": [
    "ai",
    "ai-agents",
    "security",
    "monitoring",
    "electron",
    "svelte",
    "oversight",
    "privacy",
    "edr",
    "anomaly-detection"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/electron": "^1.4.38",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "sharp": "^0.34.5",
    "svelte": "^5.53.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  }
}
