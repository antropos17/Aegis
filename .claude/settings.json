{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(.claude/**)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx vitest *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npm audit:*)",
      "Bash(npm ls:*)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(powershell.exe *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(rm -rf *)",
      "Bash(npm publish *)",
      "Edit(.env*)",
      "Edit(*.pem)",
      "Edit(*credential*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(find * -delete:*)",
      "Bash(find * -exec:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ \"$(git branch --show-current)\" != \"master\" ] || { echo '{\"block\": true, \"message\": \"Cannot edit on master. Create feature branch first.\"}' >&2; exit 2; }",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(src/**/*.svelte)",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --check \"$TOOL_INPUT_path\" 2>/dev/null || echo 'Prettier warning: file not formatted'",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Task complete. Remember: commit if done, /compact if >50% context.'",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory"
}
